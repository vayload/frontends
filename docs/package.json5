{
	name: '@vayload/file-transfer',
	display_name: 'File Transfer',
	version: '1.0.2',
	description: 'High-performance file upload/download plugin with stress testing tools.',
	license: 'MIT',
	keywords: ['filesystem', 'network', 'benchmark'],
	tags: ['filesystem', 'network', 'benchmark'],
	homepage: 'https://vayload.dev/plugins/file-transfer',
	repository: {
		type: 'git',
		url: 'git+https://github.com/vayload/file-transfer.git',
	},
	author: 'Vayload Team <dev@vayload.com>',
	contributors: ['Community User <user@example.com>'],
	main: 'src/init.lua',
	engines: {
		lua: '5.1',
		host: '^2.0.0', // Vayload Host API version
	},

	dependencies: {
		'lua-json': '^1.3.0',
		'http-client': '^2.0.0',
	},
	dev_dependencies: {
		busted: '^2.0.0',
		luacheck: '^0.26.0',
	},
	host_dependencies: {
		'kernel.events': '*',
		'kernel.http': '*',
		'std.fs': 'v2',
	},

	scripts: {
		test: 'busted spec/',
		lint: 'luacheck src/',
		build: 'vlk pack --output dist/',
		bench: 'lua benchmarks/upload_stress.lua',
	},

	permissions: {
		filesystem: {
			scope: 'read-write', // read-only, read-write, none
			allow: ['./uploads', './logs'],
			deny: ['/etc', '/usr'], // Is imposible to access
		},

		network: {
			allow_outbound: ['api.aws.com', '*.myservice.io'],
			allow_inbound: false, // Disable inbound connections
		},

		limits: {
			max_memory_mb: 128,
			max_execution_time_ms: 5000,
			max_threads: 2,
		},
	},

	config: {
		max_file_size: 10485760,
		chunk_size: 4096,
		retry_attempts: 3,
		features: {
			stress_test: true,
			metrics: false,
		},
	},
}

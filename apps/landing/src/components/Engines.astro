<section id="engines" class="py-24 px-6 max-w-7xl mx-auto">
    <div class="mb-12 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
            Built for <span class="text-orange-500">Performance</span>
        </h2>
        <p class="text-neutral-400 max-w-2xl mx-auto">
            Two powerful engines working in harmony. Go for raw speed and
            concurrency, Lua for extensibility and safety.
        </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        <div
            class="md:col-span-8 p-8 rounded-xl bg-vayload-bg-card border border-white/5 relative overflow-hidden group hover:border-cyan-500/30 transition-colors vayload-card"
        >
            <div
                class="absolute top-0 right-0 p-32 bg-cyan-900/10 blur-[80px] rounded-full group-hover:bg-cyan-600/20 transition-all duration-700"
            >
            </div>
            <div class="relative z-10">
                <div class="flex items-center gap-3 mb-4">
                    <div>

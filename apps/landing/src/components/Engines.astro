                                </g>
                            </g>
                        </svg>
                    </div>
                    <h3 class="text-2xl font-bold text-white">
                        Backend in Golang
                    </h3>
                </div>
                <p class="text-neutral-400 text-lg leading-relaxed max-w-xl">
                    Native concurrency with Goroutines ensures Vayload serves
                    millions of requests with minimal resources. Produces a
                    single static binary. No "dependency hell".
                </p>
                <div class="mt-8 flex gap-4 flex-wrap">
                    <span
                        class="px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wide border bg-cyan-900/10 border-cyan-500/20 text-cyan-400"
                    >
                        Zero Dependencies
                    </span>
                    <span
                        class="px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wide border bg-cyan-900/10 border-cyan-500/20 text-cyan-400"
                    >
                        &lt; 20MB Binary
                    </span>
                    <span
                        class="px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wide border bg-cyan-900/10 border-cyan-500/20 text-cyan-400"
                    >
                        Goroutines
                    </span>
                </div>
            </div>
        </div>

        <div
            class="md:col-span-4 p-8 rounded-xl bg-vayload-bg-card border border-white/5 relative overflow-hidden group hover:border-orange-500/30 transition-colors vayload-card"
        >
            <div
                class="absolute bottom-0 left-0 p-24 bg-orange-900/10 blur-[60px] rounded-full group-hover:bg-orange-600/20 transition-all duration-700"
            >
            </div>
            <div class="relative z-10">
                <div class="flex items-center gap-3 mb-4">
                    <div class="text-orange-500 pr-1">
                        <svg
                            width="32"
                            height="32"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                            role="img"
                            xmlns="http://www.w3.org/2000/svg"
                            ><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g
                                id="SVGRepo_tracerCarrier"
                                stroke-linecap="round"
                                stroke-linejoin="round"></g><g
                                id="SVGRepo_iconCarrier"
                                ><path
                                    d="m.38 10.377-.272-.037c-.048.344-.082.695-.101 1.041l.275.016c.018-.34.051-.682.098-1.02zm3.756-7.088-.184-.205c-.258.232-.509.48-.746.734l.202.188c.231-.248.476-.49.728-.717zm1.633-1.23-.146-.235c-.296.186-.586.385-.863.594l.166.219c.27-.203.554-.399.843-.578zm-3.945 16.31c.185.297.384.586.593.863l.22-.164a11.668 11.668 0 0 1-.58-.844l-.233.145zm-.697-1.967-.255.104c.129.318.274.635.431.943l.005.01.245-.125-.005-.01a11.931 11.931 0 0 1-.421-.922zM.298 9.309l.269.063c.076-.332.168-.664.272-.986l-.261-.087c-.108.332-.202.672-.28 1.01zM.274 12.42l-.275.01c.012.348.04.699.083 1.043l.273-.033c-.042-.336-.069-.68-.081-1.02zm-.018 2.086c.073.34.162.682.264 1.014l.263-.08c-.1-.326-.187-.658-.258-.99l-.269.056zM11.573.275 11.563 0c-.348.012-.699.039-1.044.082l.034.273c.338-.041.68-.068 1.02-.08zm11.648 8.291c.1.326.186.66.256.992l.27-.059c-.072-.34-.16-.682-.262-1.014l-.264.081zm-5.6-7.177a11.849 11.849 0 0 0-.947-.449l-.107.252c.314.133.625.281.926.439l.128-.242zM15.693.572c-.332-.105-.67-.199-1.01-.277l-.063.268c.332.076.664.168.988.273l.085-.264zm-9.019.973c.298-.15.606-.291.916-.418L7.486.873c-.317.127-.632.272-.937.428l-.015.008.125.244.015-.008zm17.053 10.043.275-.01a11.797 11.797 0 0 0-.082-1.045l-.273.033c.041.338.068.682.08 1.022zM13.654.105c-.346-.047-.696-.08-1.043-.098l-.014.273c.339.018.683.051 1.019.098l.038-.273zm-4.11.422-.058-.27c-.34.072-.681.16-1.014.264l.081.262c.325-.099.659-.185.991-.256zM1.921 5.469l.231.15c.185-.285.384-.566.592-.834l-.217-.17c-.213.276-.417.563-.606.854zM.943 7.318l.253.107c.132-.313.28-.625.439-.924l-.243-.128c-.163.307-.314.625-.449.945zm17.28 14.625.145.234c.295-.186.586-.385.863-.594l-.164-.219c-.272.204-.557.4-.844.579zm3.025-2.724.217.17c.215-.273.418-.561.607-.854l-.23-.148c-.186.285-.385.564-.594.832zm-1.393 1.496.184.203c.258-.23.51-.479.746-.732l-.201-.188c-.23.248-.477.488-.729.717zm2.504-3.211.244.129c.162-.307.314-.625.449-.945l-.254-.107a11.27 11.27 0 0 1-.439.923zm1.258-3.875.273.
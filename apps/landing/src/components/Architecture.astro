---

---

<section id="architecture" class="py-32 bg-[#08080a] relative overflow-hidden border-y border-white/5">
	<div class="max-w-7xl mx-auto px-6 relative z-10">
		<div class="text-center mb-16">
			<h2 class="text-3xl md:text-5xl font-bold text-white mb-6">
				Microkernel <span class="text-orange-500">Architecture</span>
			</h2>
			<p class="text-neutral-400 max-w-3xl mx-auto text-lg">
				A three-tier architecture designed for extensibility. From the core kernel to sandboxed plugins, every
				layer has a specific responsibility.
			</p>
		</div>

		<div class="grid md:grid-cols-2 gap-12 items-start">
			<div class="space-y-8">
				<div class="p-6 rounded-xl bg-vayload-bg-elevated border border-white/10 vayload-card">
					<div class="flex items-center gap-3 mb-3">
						<div class="p-2 rounded bg-orange-900/20 text-orange-500">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="20"
								height="20"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<circle cx="12" cy="12" r="3"></circle>
								<path
									d="M12 1v6m0 6v6m4.22-10.22l4.24-4.24M6.34 17.66l-4.24 4.24M23 12h-6m-6 0H1m20.24 4.24l-4.24-4.24M6.34 6.34L2.1 2.1"
								></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold text-white">Level 1: Kernel</h3>
					</div>
					<p class="text-neutral-400 text-sm leading-relaxed">
						The core manages fundamental components: Dependency Injection (DI), Event Bus, Job Queue, Lua
						VM, and the Plugin Orchestrator. This is the foundation that everything else builds upon.
					</p>
				</div>

				<div class="p-6 rounded-xl bg-vayload-bg-elevated border border-white/10 vayload-card">
					<div class="flex items-center gap-3 mb-3">
						<div class="p-2 rounded bg-cyan-900/20 text-cyan-500">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="20"
								height="20"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
								<line x1="8" y1="21" x2="16" y2="21"></line>
								<line x1="12" y1="17" x2="12" y2="21"></line>
							</svg>
						</div>
						<h3 class="text-xl font-bold text-white">Level 2: Services</h3>
					</div>
					<p class="text-neutral-400 text-sm leading-relaxed">
						Services register with the kernel and can interoperate with each other. The API is simple and
						allows embedding new services seamlessly. Note: Still in alpha, subject to changes.
					</p>
				</div>

				<div class="p-6 rounded-xl bg-vayload-bg-elevated border border-white/10 vayload-card">
					<div class="flex items-center gap-3 mb-3">
						<div class="p-2 rounded bg-purple-900/20 text-purple-500">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="20"
								height="20"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path
									d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"
								></path>
								<polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
								<line x1="12" y1="22.08" x2="12" y2="12"></line>
							</svg>
						</div>
						<h3 class="text-xl font-bold text-white">Level 3: Plugins (Lua)</h3>
					</div>
					<p class="text-neutral-400 text-sm leading-relaxed">
						Extend CMS functionality via Lua. The API is documented in the Vayload Plug developer docs.
						<strong>Security:</strong> Plugins run in sandbox mode, limited to what the kernel offers as host.
					</p>
				</div>
			</div>

			<div class="p-8 rounded-2xl bg-[#0a0a0c] border border-orange-500/20 shadow-2xl relative font-mono text-xs">
				<div
					class="absolute -top-3 -right-3 bg-orange-600 text-white font-bold px-3 py-1 rounded-full text-xs shadow-lg"
				>
					ARCHITECTURE
				</div>

				<div class="space-y-3">
					<div class="text-neutral-500 mb-4 text-sm">// Request Flow</div>

					<div class="flex items-center gap-2 p-3 bg-black/40 border border-white/5 rounded">
						<span class="text-blue-400 font-bold">→</span>
						<span class="text-white">Request</span>
					</div>

					<div class="flex items-center gap-2 p-3 bg-black/40 border border-white/5 rounded ml-4">
						<span class="text-cyan-400 font-bold">↓</span>
						<span class="text-neutral-300">Middlewares / Guards</span>
					</div>

					<div class="flex items-center gap-2 p-3 bg-orange-900/20 border border-orange-500/30 rounded ml-8">
						<span class="text-orange-400 font-bold">⚡</span>
						<span class="text-white font-bold">Kernel</span>
						<span class="text-neutral-500 text-xs">(DI, Event Bus, Job Queue, Lua VM)</span>
					</div>

					<div class="flex items-center gap-2 p-3 bg-black/40 border border-white/5 rounded ml-12">
						<span class="text-purple-400 font-bold">↓</span>
						<span class="text-neutral-300">Router</span>
						<span class="text-neutral-500 text-xs">(HTTP / gRPC / MCP)</span>
					</div>

					<div class="flex items-center gap-2 p-3 bg-black/40 border border-white/5 rounded ml-16">
						<span class="text-yellow-400 font-bold">↓</span>
						<span class="text-neutral-300">Handlers</span>
					</div>

					<div class="flex items-center gap-2 p-3 bg-cyan-900/10 border border-cyan-500/20 rounded ml-20">
						<span class="text-cyan-400 font-bold">↓</span>
						<span class="text-white">Services</span>
					</div>

					<div class="flex items-center gap-2 p-3 bg-purple-900/10 border border-purple-500/20 rounded ml-24">
						<span class="text-purple-400 font-bold">◇</span>
						<span class="text-neutral-300">Plugins (Lua)</span>
						<span class="text-neutral-500 text-xs">if needed</span>
					</div>
				</div>

				<div class="mt-8 pt-4 border-t border-white/5 text-xs">
					<div class="flex gap-4 flex-wrap">
						<div class="flex items-center gap-2">
							<div class="w-3 h-3 rounded bg-orange-900/30 border border-orange-500/30"></div>
							<span class="text-neutral-400">Kernel</span>
						</div>
						<div class="flex items-center gap-2">
							<div class="w-3 h-3 rounded bg-cyan-900/10 border border-cyan-500/20"></div>
							<span class="text-neutral-400">Services</span>
						</div>
						<div class="flex items-center gap-2">
							<div class="w-3 h-3 rounded bg-purple-900/10 border border-purple-500/20"></div>
							<span class="text-neutral-400">Plugins</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

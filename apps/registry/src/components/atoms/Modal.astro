---
interface Props {
	id: string;
	title?: string;
	className?: string;
}

const { id, title, className = '' } = Astro.props;
---

<div
	id={id}
	class="fixed inset-0 z-50 items-center justify-center p-4 bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-200 hidden"
	data-modal
>
	<div
		class={`bg-neutral-900 border border-neutral-800 rounded-xl w-full max-w-lg shadow-2xl scale-95 transition-transform duration-200 ${className}`}
		data-modal-content
	>
		<div class="flex items-center justify-between px-6 py-4 border-b border-neutral-800">
			{title && <h3 class="text-lg font-bold text-white">{title}</h3>}
			<button
				class="text-neutral-500 hover:text-white transition-colors"
				data-close-modal
				aria-label="Close modal"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="20"
					height="20"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<line x1="18" y1="6" x2="6" y2="18"></line>
					<line x1="6" y1="6" x2="18" y2="18"></line>
				</svg>
			</button>
		</div>
		<div class="p-6">
			<slot />
		</div>
		<slot name="footer" />
	</div>
</div>

<script>
	import { $ } from '../../common/micro';

	// Auto-setup for modal close buttons
	$(document.documentElement).on('click', (e) => {
		const target = e.target as HTMLElement;
		if (target.closest('[data-close-modal]')) {
			const modal = target.closest('[data-modal]');
			if (modal) {
				$(modal as HTMLElement)
					.removeClass('opacity-100', 'pointer-events-auto')
					.addClass('opacity-0', 'pointer-events-none');

				setTimeout(() => $(modal as HTMLElement).addClass('hidden'), 200);
			}
		}
	});
</script>

---
interface Props {
	className?: string;
	id?: string;
	name?: string;
	checked?: boolean;
	disabled?: boolean;
	label?: string;
}

const { className = '', id, name, checked = false, disabled = false, label, ...props } = Astro.props;
---

<label
	class={`flex items-center gap-3 cursor-pointer group ${disabled ? 'opacity-50 cursor-not-allowed' : ''} ${className}`}
>
	<div class="relative inline-flex items-center">
		<input
			id={id}
			type="checkbox"
			role="switch"
			name={name}
			checked={checked}
			disabled={disabled}
			class="peer sr-only"
			{...props}
		/>
		<div
			class="w-10 h-6 bg-neutral-800 rounded-full peer peer-checked:bg-orange-600 transition-colors after:content-[''] after:absolute after:top-1 after:left-1 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-4"
		>
		</div>
	</div>
	{label && <span class="text-sm text-neutral-300 group-hover:text-white transition-colors">{label}</span>}
</label>

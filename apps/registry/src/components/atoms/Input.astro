---
interface Props {
	type?: 'text' | 'email' | 'password' | 'number' | 'url' | 'search';
	placeholder?: string;
	className?: string;
	id?: string;
	name?: string;
	value?: string;
	required?: boolean;
	disabled?: boolean;
	error?: string;
}

const {
	type = 'text',
	placeholder,
	className = '',
	id,
	name,
	value,
	required = false,
	disabled = false,
	error,
	...props
} = Astro.props;
---

<div class="space-y-1.5 w-full">
	<input
		id={id}
		type={type}
		name={name}
		value={value}
		placeholder={placeholder}
		required={required}
		disabled={disabled}
		class={`w-full bg-neutral-950 border border-neutral-800 rounded-lg px-4 py-2.5 text-white outline-none focus:border-orange-500 transition-all text-sm placeholder:text-neutral-600 disabled:opacity-50 disabled:cursor-not-allowed ${error ? 'border-red-500 focus:border-red-500' : ''} ${className}`}
		{...props}
	/>
	{error && <p class="text-xs text-red-500">{error}</p>}
</div>

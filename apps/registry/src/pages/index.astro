---
import Layout from '../layouts/Layout.astro';
import { HeroBrowseSection } from '@/components/landing/HeroBrowseSection';
import Logo from '@/components/brand/Logo.astro';
import Zap from '@/components/icons/Zap.astro';
import Button from '@/components/atoms/Button.astro';
import UploadCloud from '@/components/icons/UploadCloud.astro';
import Code2 from '@/components/icons/Code2.astro';
---

<Layout title="Vayload Registry - Plugins & Scripts">
	<section class="relative min-h-[90vh] flex items-center overflow-hidden bg-neutral-950 pt-20 pb-12">
		<div class="container mx-auto px-6 relative z-10">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
				<div class="flex flex-col space-y-8 animate-in slide-in-from-left-8 fade-in duration-1000">
					<div>
						<div class="mb-4 size-16 animate-in fade-in zoom-in duration-700">
							<Logo class="w-full drop-shadow-2xl [&>svg]:w-full [&>svg]:h-auto text-white" />
						</div>

						<div
							class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-orange-500/10 border border-orange-500/20 text-orange-500 text-xs font-medium mb-6"
						>
							<Zap size={14} class="fill-current" />
							<span>Vayload Registry v2.0</span>
						</div>

						<h1
							class="text-5xl md:text-6xl lg:text-7xl font-bold text-white tracking-tight leading-[1.1] mb-6"
						>
							Extend your <br />
							<span
								class="relative inline-block text-transparent bg-clip-text bg-linear-to-r from-orange-400 via-orange-500 to-amber-500"
							>
								Vayload CMS
							</span>
						</h1>

						<p class="text-lg md:text-xl text-neutral-400 max-w-xl leading-relaxed">
							Discover, install, and manage official and community-built plugins. Supercharge your
							workflow with the most powerful modular ecosystem.
						</p>
					</div>

					<div class="grid grid-cols-3 gap-8 pt-8 border-t border-neutral-900">
						<div>
							<div class="text-2xl font-bold text-white">500+</div>
							<div class="text-sm text-neutral-500">Plugins</div>
						</div>
						<div>
							<div class="text-2xl font-bold text-white">12k</div>
							<div class="text-sm text-neutral-500">Installs/mo</div>
						</div>
						<div>
							<div class="text-2xl font-bold text-white">2k+</div>
							<div class="text-sm text-neutral-500">Developers</div>
						</div>
					</div>
				</div>
				<HeroBrowseSection client:load />
			</div>
		</div>
	</section>
</Layout>
